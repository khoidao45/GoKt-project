# Copy this file to .env and fill in your values
# .env is gitignored — never commit real secrets

# PostgreSQL
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=GoktDb;Username=postgres;Password=YOUR_DB_PASSWORD

# Redis (leave empty to use in-memory cache)
ConnectionStrings__Redis=

# JWT
Jwt__Secret=YOUR_JWT_SECRET_AT_LEAST_32_CHARS_LONG
Jwt__Issuer=gokt-api
Jwt__Audience=gokt-clients
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=30

# SendGrid
SendGrid__ApiKey=YOUR_SENDGRID_API_KEY
SendGrid__FromEmail=YOUR_SENDER_NAME
SendGrid__FromName=Gokt

# App
App__BaseUrl=http://localhost:5042
